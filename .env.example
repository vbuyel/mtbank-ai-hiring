# Local host (uvicorn): http://127.0.0.1:11434/v1
# Docker Compose:        http://host.docker.internal:11434/v1
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=ollama
# Must match `ollama list` (e.g. llama3.2, qwen2.5:7b)
LLM_MODEL=llama3.2
# tiny/base — быстрый локальный старт; medium — для сдачи ТЗ
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
MAX_AUDIO_BYTES=52428800
LOG_LEVEL=INFO
